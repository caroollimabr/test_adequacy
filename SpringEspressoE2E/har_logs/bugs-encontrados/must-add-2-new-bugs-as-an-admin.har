            "mimeType": "text/css;charset=UTF-8",
            "compression": 0,
            "text": "/* src/main/resources/static/css/main.css */\r\n\r\n@import url('https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&family=Open+Sans:wght@300;400;600&display=swap');\r\n\r\n:root {\r\n    --cafe-escuro: #4A2B1E;\r\n    --cafe-medio: #7A4F3D;\r\n    --creme: #F5E8C7;\r\n    --laranja-suave: #FFDAB9;\r\n    --cinza-claro: #E0E0E0;\r\n    --sombra-leve: rgba(0, 0, 0, 0.1);\r\n    --borda-arredondada: 8px;\r\n}\r\n\r\nbody {\r\n    font-family: 'Maple Mono', monospace;\r\n    background: linear-gradient(to bottom, #f3e5ab, #d7ccc8);\r\n    color: var(--cafe-escuro);\r\n    margin: 0;\r\n    padding: 0;\r\n    display: flex;\r\n    flex-direction: column;\r\n    min-height: 100vh;\r\n}\r\n\r\n\r\n\r\n.wrapper {\r\n    width: 90%;\r\n    max-width: 960px;\r\n    margin: 40px auto;\r\n    background-color: rgba(255, 255, 255, 0.8);\r\n    padding: 30px;\r\n    box-shadow: 0 4px 12px var(--sombra-leve);\r\n    border-radius: var(--borda-arredondada);\r\n    flex-grow: 1;\r\n}\r\n\r\nh1, h2, h3 {\r\n    font-family: 'Maple Mono', monospace;\r\n    color: var(--cafe-escuro);\r\n    text-align: center;\r\n    margin-bottom: 25px;\r\n    letter-spacing: 0.5px;\r\n}\r\n\r\n\r\n\r\nlabel {\r\n    font-weight: 600;\r\n    margin-bottom: 5px;\r\n    color: var(--cafe-medio);\r\n}\r\n\r\ninput[type=\"text\"],\r\ninput[type=\"password\"],\r\ninput[type=\"email\"],\r\nselect {\r\n    width: calc(100% - 20px);\r\n    padding: 10px;\r\n    border: 1px solid var(--cinza-claro);\r\n    border-radius: 5px;\r\n    font-size: 1em;\r\n    color: var(--cafe-escuro);\r\n    transition: border-color 0.3s ease;\r\n}\r\n\r\ninput[type=\"text\"]:focus,\r\ninput[type=\"password\"]:focus,\r\ninput[type=\"email\"]:focus,\r\nselect:focus {\r\n    border-color: var(--laranja-suave);\r\n    outline: none;\r\n    box-shadow: 0 0 0 3px rgba(255, 218, 185, 0.5);\r\n}\r\n\r\ntd:last-of-type {\r\n    display: flex;\r\n    flex-direction: row;\r\n    flex-wrap: wrap;\r\n    gap: 8px;\r\n    align-items: center;\r\n    justify-content: flex-start;\r\n}\r\n\r\n\r\n.button,\r\nbutton[type=\"submit\"] {\r\n    display: inline-block;\r\n    padding: 7px 15px;\r\n    border: none;\r\n    border-radius: 5px;\r\n    cursor: pointer;\r\n    font-size: 1em;\r\n    text-decoration: none;\r\n    text-align: center;\r\n    transition: background-color 0.3s ease, transform 0.2s ease;\r\n}\r\n\r\n.button-primary,\r\nbutton[type=\"submit\"] {\r\n    background-color: var(--cafe-medio);\r\n    color: white;\r\n}\r\n\r\n.button-primary:hover,\r\nbutton[type=\"submit\"]:hover {\r\n    background-color: var(--cafe-escuro);\r\n    transform: translateY(-2px);\r\n}\r\n\r\n.button-secondary {\r\n    background-color: var(--cinza-claro);\r\n    color: var(--cafe-escuro);\r\n}\r\n\r\n.button-secondary:hover {\r\n    background-color: #C0C0C0;\r\n    transform: translateY(-2px);\r\n}\r\n\r\n\r\n.message-box {\r\n    padding: 15px;\r\n    margin-bottom: 20px;\r\n    border-radius: var(--borda-arredondada);\r\n    font-weight: 600;\r\n}\r\n\r\n.success {\r\n    background-color: #d4edda;\r\n    color: #155724;\r\n    border: 1px solid #c3e6cb;\r\n}\r\n\r\n.error {\r\n    background-color: #f8d7da;\r\n    color: #721c24;\r\n    border: 1px solid #f5c6cb;\r\n}\r\n\r\n\r\nheader {\r\n    background-color: var(--cafe-escuro);\r\n    color: var(--creme);\r\n    padding: 15px 0;\r\n    text-align: center;\r\n    box-shadow: 0 2px 5px var(--sombra-leve);\r\n}\r\n\r\nheader h1 {\r\n    margin: 0;\r\n    color: var(--creme);\r\n    font-size: 2em;\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n}\r\n\r\n.coffee-icon {\r\n    margin-right: 10px;\r\n    height: 30px;\r\n    width: auto;\r\n}\r\n\r\n\r\nfooter {\r\n    background-color: var(--cafe-escuro);\r\n    color: var(--creme);\r\n    text-align: center;\r\n    padding: 15px 0;\r\n    margin-top: 40px;\r\n    font-size: 0.9em;\r\n}\r\n\r\n\r\ntable {\r\n    width: 100%;\r\n    border-collapse: collapse;\r\n    margin-top: 20px;\r\n    box-shadow: 0 2px 8px rgba(0,0,0,0.05);\r\n    border-radius: var(--borda-arredondada);\r\n    overflow: hidden;\r\n    table-layout: fixed; \r\n}\r\n\r\nth, td {\r\n    border: 1px solid var(--cinza-claro);\r\n    padding: 12px 15px;\r\n    text-align: left;\r\n}\r\n\r\nth {\r\n    background-color: var(--laranja-suave);\r\n    color: var(--cafe-escuro);\r\n    font-weight: 700;\r\n    text-transform: uppercase;\r\n}\r\n\r\n\r\n.table th span {\r\n    margin-right: 5px;\r\n    display: inline-block; \r\n}\r\n\r\n.table th a {\r\n    text-decoration: none;\r\n    color: var(--cafe-medio);\r\n    font-size: 0.9em;\r\n    margin-left: 2px;\r\n    vertical-align: middle;\r\n    transition: color 0.2s ease-in-out;\r\n    white-space: nowrap;\r\n}\r\n\r\n.table th a:hover {\r\n    color: var(--cafe-escuro);\r\n}\r\n\r\n\r\n.table th:nth-child(2) {\r\n    width: 50%;\r\n}\r\n\r\n\r\n.table th:nth-child(1) {\r\n    width: 20%;\r\n}\r\n\r\n.table th:nth-child(3) {\r\n    width: 50%;\r\n}\r\n\r\n.table th:nth-child(4) {\r\n    white-space: nowrap;\r\n    min-width: 300px;\r\n    width: 70%;\r\n}\r\n\r\n\r\n.table th:nth-child(5) {\r\n    width: 60%;\r\n}\r\n\r\n.table th:nth-child(6) {\r\n    width: 50%;\r\n}\r\n\r\n\r\n\r\ntr:nth-child(even) {\r\n    background-color: #f9f9f9;\r\n}\r\n\r\ntr:hover {\r\n    background-color: #f1f1f1;\r\n}\r\n\r\n\r\n@media (max-width: 768px) {\r\n    .wrapper {\r\n        margin: 20px auto;\r\n        padding: 20px;\r\n    }\r\n\r\n    th, td {\r\n        padding: 8px 10px;\r\n    }\r\n\r\n    \r\n    .table th:nth-child(2),\r\n    .table th:nth-child(4) {\r\n        min-width: unset; \r\n        width: auto;\r\n    }\r\n}\r\n\r\n@media (max-width: 480px) {\r\n    h1 {\r\n        font-size: 1.5em;\r\n    }\r\n\r\n    .button,\r\n    button[type=\"submit\"] {\r\n        padding: 8px 15px;\r\n        font-size: 0.9em;\r\n    }\r\n\r\n    \r\n    table, thead, tbody, th, td, tr {\r\n        display: block;\r\n    }\r\n\r\n    thead tr {\r\n        position: absolute;\r\n        top: -9999px;\r\n        left: -9999px;\r\n    }\r\n\r\n    tr { border: 1px solid var(--cinza-claro); margin-bottom: 10px; border-radius: var(--borda-arredondada); }\r\n\r\n    td {\r\n        border: none;\r\n        border-bottom: 1px solid #eee;\r\n        position: relative;\r\n        padding-left: 50%;\r\n        text-align: right;\r\n    }\r\n\r\n    td:before {\r\n        position: absolute;\r\n        top: 6px;\r\n        left: 6px;\r\n        width: 45%;\r\n        padding-right: 10px;\r\n        white-space: nowrap;\r\n        text-align: left;\r\n        font-weight: 600;\r\n        color: var(--cafe-medio);\r\n    }\r\n\r\n    td:nth-of-type(1):before { content: \"ID:\"; }\r\n    td:nth-of-type(2):before { content: \"Nome:\"; }\r\n    td:nth-of-type(3):before { content: \"Descrição:\"; }\r\n    td:nth-of-type(4):before { content: \"Data de Criação:\"; }\r\n    td:nth-of-type(5):before { content: \"Membros:\"; }\r\n    td:nth-of-type(6):before { content: \"Ações:\"; }\r\n}\r\n\r\n\r\n.dashboard-grid {\r\n    display: grid;\r\n    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\r\n    gap: 25px;\r\n    margin-top: 30px;\r\n}\r\n\r\n.card {\r\n    background-color: #fff;\r\n    border: 1px solid var(--cinza-claro);\r\n    border-radius: var(--borda-arredondada);\r\n    padding: 25px;\r\n    box-shadow: 0 4px 10px rgba(0,0,0,0.08);\r\n    text-align: center;\r\n    transition: transform 0.3s ease, box-shadow 0.3s ease;\r\n}\r\n\r\n.card:hover {\r\n    transform: translateY(-5px);\r\n    box-shadow: 0 6px 15px rgba(0,0,0,0.12);\r\n}\r\n\r\n.card h3 {\r\n    font-size: 1.5em;\r\n    margin-top: 0;\r\n    margin-bottom: 15px;\r\n    color: var(--cafe-escuro);\r\n}\r\n\r\n.card p {\r\n    font-size: 0.95em;\r\n    color: var(--cafe-medio);\r\n    line-height: 1.5;\r\n    margin-bottom: 20px;\r\n}\r\n\r\n.card .button {\r\n    width: auto;\r\n    padding: 10px 25px;\r\n}\r\n\r\n.logout {\r\n    max-width: 40%;\r\n    margin-left: 27.5%;\r\n}\r\n\r\n.id-table {\r\n    word-break: break-all;\r\n}\r\n\r\n\r\n.navigation-section {\r\n    margin-top: 40px;\r\n    padding-top: 20px;\r\n    border-top: 2px solid #E0E0E0;\r\n    text-align: center;\r\n}\r\n\r\n.navigation-section .button {\r\n    margin: 0 5px;\r\n    transition: all 0.3s ease;\r\n}\r\n\r\n.navigation-section .button:hover {\r\n    transform: translateY(-2px);\r\n    box-shadow: 0 4px 8px rgba(0,0,0,0.15);\r\n}\r\n\r\n\r\n@media (max-width: 480px) {\r\n    .navigation-section {\r\n        margin-top: 30px;\r\n        padding-top: 15px;\r\n    }\r\n\r\n    .navigation-section .button {\r\n        display: block;\r\n        margin: 10px auto;\r\n        max-width: 200px;\r\n    }\r\n}\r\n\r\n.lang-button {\r\n    background-color: rgba(0,0,0,0%);\r\n    border: rgba(0,0,0,0%);\r\n}\r\n\r\n.lang-button button:hover {\r\n    background-color: #c68062;\r\n}\r\n\r\n.id-table2 {\r\n    word-break: break-all;\r\n}\r\n\r\n.id-table {\r\n    max-width: 150px;\r\n    white-space: nowrap;\r\n    overflow: hidden;\r\n    text-overflow: ellipsis;\r\n}\r\n\r\n/* estilos específicos do header - alta especificidade para evitar sobrescrita */\r\n#site-header {\r\n    display: flex !important;\r\n    align-items: center !important;\r\n    justify-content: space-between !important;\r\n    padding: 10px 20px !important; /* padding horizontal bonitinho */\r\n    width: 100%;\r\n    box-sizing: border-box;\r\n}\r\n\r\n#site-header .header-left,\r\n#site-header .header-right,\r\n#site-header .header-center {\r\n    flex: 1;        /* 3 colunas iguais */\r\n    display: flex;\r\n    align-items: center;\r\n}\r\n\r\n#site-header .header-center {\r\n    justify-content: center !important; /* centraliza o título */\r\n}\r\n\r\n#site-header .header-right {\r\n    justify-content: flex-end !important; \r\n}\r\n\r\n#site-header .header-right button {\r\n    margin-right: 10px; /* small spacing from the right edge */\r\n}"
          },
