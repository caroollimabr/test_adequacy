            "text": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>Relatório de Bugs</title>\r\n    <link rel=\"stylesheet\" href=\"/css/main.css\"/>\r\n    <style>\r\n        table.report-table {\r\n            width: 100%;\r\n            border-collapse: collapse;\r\n            table-layout: fixed; \r\n        }\r\n\r\n        table.report-table th,\r\n        table.report-table td {\r\n            padding: 12px 8px;\r\n            word-wrap: break-word;\r\n            overflow: hidden;\r\n            text-overflow: ellipsis;\r\n            white-space: nowrap; \r\n        }\r\n\r\n        td.col-bug {\r\n            white-space: normal;\r\n        }\r\n\r\n        col.col-projeto      { width: 15%; }\r\n        col.col-bug          { width: 32%; }\r\n        col.col-criticidade  { width: 12%; }\r\n        col.col-resolvido    { width: 12%; }\r\n        col.col-data         { width: 18%; }\r\n        col.col-actions      { width: 10%; } \r\n\r\n        .bug-id { font-weight: bold; color: var(--cafe-escuro); display: block; }\r\n        .action-link { display: inline-block; width: 34px; height: 28px; line-height: 26px; text-align: center; }\r\n    </style>\r\n</head>\r\n<body>\r\n\r\n<div><header id=\"site-header\">\r\n    <div class=\"header-left\"></div>\r\n\r\n    <div class=\"header-center\">\r\n        <h1>☕ Spring Espresso Game Testing</h1>\r\n    </div>\r\n\r\n    <div class=\"header-right\">\r\n        <form action=\"/logout\" method=\"post\" class=\"logout\">\r\n            <button type=\"submit\" class=\"button button-secondary\">Sair</button>\r\n        </form>\r\n    </div>\r\n</header></div>\r\n\r\n<div class=\"wrapper\">\r\n    <h1>Relatório de Bugs</h1>\r\n\r\n    \r\n    \r\n\r\n    <table class=\"report-table table-striped table-bordered\">\r\n        <colgroup>\r\n            <col class=\"col-projeto\"/>\r\n            <col class=\"col-bug\"/>\r\n            <col class=\"col-criticidade\"/>\r\n            <col class=\"col-resolvido\"/>\r\n            <col class=\"col-data\"/>\r\n            <col class=\"col-actions\"/>\r\n        </colgroup>\r\n\r\n        <thead>\r\n        <tr>\r\n            <th>Projeto</th>\r\n            <th>Bug</th>\r\n            <th>Criticidade</th>\r\n            <th>Resolvido?</th>\r\n            <th>Data</th>\r\n            <th>Ações</th>\r\n        </tr>\r\n        </thead>\r\n\r\n        <tbody>\r\n        <tr>\r\n            <td>Projeto Alpha</td>\r\n\r\n            <td class=\"col-bug\">\r\n                <span class=\"bug-id\">BugBugTeste1</span>\r\n            </td>\r\n\r\n            <td>Média</td>\r\n\r\n            <td style=\"text-align:center;\">❌</td>\r\n\r\n            <td>09/06/2026 09:51</td>\r\n\r\n            <td style=\"text-align:center;\">\r\n                <a href=\"/bugs/detalhes/2\"\r\n                   class=\"button button-secondary small action-link\"\r\n                   title=\"Ver detalhes\">Ver</a>\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td>Projeto Alpha</td>\r\n\r\n            <td class=\"col-bug\">\r\n                <span class=\"bug-id\">BugTesteUser1</span>\r\n            </td>\r\n\r\n            <td>Crítica</td>\r\n\r\n            <td style=\"text-align:center;\">❌</td>\r\n\r\n            <td>09/06/2026 09:51</td>\r\n\r\n            <td style=\"text-align:center;\">\r\n                <a href=\"/bugs/detalhes/1\"\r\n                   class=\"button button-secondary small action-link\"\r\n                   title=\"Ver detalhes\">Ver</a>\r\n            </td>\r\n        </tr>\r\n        <tr>\r\n            <td>Projeto Alpha</td>\r\n\r\n            <td class=\"col-bug\">\r\n                <span class=\"bug-id\">BugBugTeste3</span>\r\n            </td>\r\n\r\n            <td>Média</td>\r\n\r\n            <td style=\"text-align:center;\">❌</td>\r\n\r\n            <td>09/06/2026 09:51</td>\r\n\r\n            <td style=\"text-align:center;\">\r\n                <a href=\"/bugs/det