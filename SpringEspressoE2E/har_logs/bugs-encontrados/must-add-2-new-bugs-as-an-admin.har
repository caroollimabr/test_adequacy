          "content": {
            "size": 3324,
            "mimeType": "text/html;charset=UTF-8",
            "compression": 0,
            "text": "<!DOCTYPE html>\r\n<html lang=\"pt-br\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>Cadastrar Bug</title>\r\n    <link rel=\"stylesheet\" href=\"/css/main.css\"/>\r\n</head>\r\n<body>\r\n\r\n<div><header id=\"site-header\">\r\n    <div class=\"header-left\"></div>\r\n\r\n    <div class=\"header-center\">\r\n        <h1>☕ Spring Espresso Game Testing</h1>\r\n    </div>\r\n\r\n    <div class=\"header-right\">\r\n        <form action=\"/logout\" method=\"post\" class=\"logout\">\r\n            <button type=\"submit\" class=\"button button-secondary\">Sair</button>\r\n        </form>\r\n    </div>\r\n</header></div>\r\n\r\n<div class=\"wrapper\">\r\n    <h1>Cadastrar Novo Bug</h1>\r\n    \r\n    \r\n    \r\n    \r\n    <div class=\"card\" style=\"margin-bottom: 20px;\">\r\n        <h3>Informações da Sessão</h3>\r\n        <p><strong>Projeto:</strong> <span>Projeto Alpha</span></p>\r\n        <p><strong>Estratégia:</strong> <span>Overtime</span></p>\r\n        <p><strong>Descrição da Sessão:</strong> <span>SessãoTesteBug3</span></p>\r\n    </div>\r\n    \r\n    <form action=\"/bugs/cadastro\" method=\"post\" enctype=\"multipart/form-data\" class=\"card\">\r\n        <input type=\"hidden\" name=\"idSessao\" value=\"125\"/>\r\n        \r\n        <div class=\"form-group\" style=\"margin-bottom: 15px;\">\r\n            <label for=\"descricao\" style=\"display: block; margin-bottom: 5px; font-weight: bold;\">Descrição do Bug: *</label>\r\n            <textarea id=\"descricao\" name=\"descricao\" required \r\n                      placeholder=\"Descreva detalhadamente o bug encontrado...\"\r\n                      rows=\"5\" style=\"width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px; resize: vertical;\"></textarea>\r\n        </div>\r\n        \r\n        <div class=\"form-group\" style=\"margin-bottom: 15px;\">\r\n            <label for=\"criticidade\" style=\"display: block; margin-bottom: 5px; font-weight: bold;\">Criticidade:</label>\r\n            <select id=\"criticidade\" name=\"criticidade\" \r\n                    style=\"width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;\" required >\r\n                <option value=\"\"></option>\r\n                <option value=\"BAIXA\">Baixa</option>\r\n                <option value=\"MEDIA\">Média</option>\r\n                <option value=\"CRITICA\">Crítica</option>\r\n            </select>\r\n        </div>\r\n        \r\n        <div class=\"form-group\" style=\"margin-bottom: 15px;\">\r\n            <label for=\"arquivo\" style=\"display: block; margin-bottom: 5px; font-weight: bold;\">Anexar Arquivo (Imagem ou Vídeo):</label>\r\n            <input type=\"file\" id=\"arquivo\" name=\"arquivo\" \r\n                   accept=\"image/*,video/*\"\r\n                   style=\"width: 100%; padding: 8px; border: 1px solid #ddd; border-radius: 4px;\"/>\r\n            <small style=\"color: #666; font-size: 0.9em;\">Formatos aceitos: JPG, PNG, GIF, MP4, WEBM (máx. 5MB)</small>\r\n        </div>\r\n        \r\n        <div class=\"form-actions\" style=\"margin-top: 20px;\">\r\n            <button type=\"submit\" class=\"button button-primary\">Cadastrar Bug</button>\r\n            <a href=\"/sessoes/detalhes/125\" \r\n               class=\"button button-secondary\">Cancelar</a>\r\n        </div>\r\n    </form>\r\n</div>\r\n\r\n<footer>\r\n    <p>Spring Espresso Game Testing. Um Software Open-source para a disciplina de Desenvolvimento Web.</p>\r\n    <p>Desenvolvido com café e paixão!</p>\r\n\r\n\r\n\r\n</footer>\r\n</body>\r\n</html>\r\n"
          },
