n                        </td>\r\n                        \r\n                        <td class=\"actions\">\r\n                            <a href=\"/projetos/detalhes/17\" class=\"button button-secondary\">Ver Detalhes</a>\r\n                            <span>\r\n                                <a href=\"/projetos/editar/17\" \r\n                                   class=\"button button-secondary\">Editar</a>\r\n                                <a href=\"/projetos/remover/17\" \r\n                                   class=\"button button-secondary\" style=\"margin-top: 8px\"\r\n                                   onclick=\"return confirm('Tem certeza que deseja remover este projeto?')\">Remover</a>\r\n                            </span>\r\n                        </td>\r\n                    </tr>\r\n                </tbody>\r\n            </table>\r\n        </div>\r\n    </div>\r\n\r\n    \r\n\r\n    <div class=\"navigation-section\">\r\n    <a href=\"/\" class=\"button button-secondary\">Main Menu</a>\r\n</div>\r\n</div>\r\n\r\n<footer>\r\n    <p>Spring Espresso Game Testing. Um Software Open-source para a disciplina de Desenvolvimento Web.</p>\r\n    <p>Desenvolvido com café e paixão!</p>\r\n\r\n\r\n\r\n</footer>\r\n\r\n</body>\r\n</html>\r\n"
