                           <span>1</span>x🥉\r\n                                    </span>\r\n                                </div>\r\n                                \r\n                                \r\n                            </div>\r\n                        </td>\r\n                        \r\n                        <!-- MEMBROS -->\r\n                        <td class=\"membros-cell\">\r\n                            <span>\r\n                                <div>\r\n                                    <span>Admin</span>\r\n                                </div>\r\n                            </span>\r\n                            \r\n                        </td>\r\n                        \r\n                        <td class=\"actions\">\r\n                            <a href=\"/projetos/detalhes/3\" class=\"button button-secondary\">Ver Detalhes</a>\r\n                            <span>\r\n                                <a href=\"/projetos/editar/3\" \r\n                                   class=\"button button-secondary\">Editar</a>\r\n                                <a href=\"/projetos/remover/3\" \r\n                                   class=\"button button-secondary\" style=\"margin-top: 8px\"\r\n                                   onclick=\"return confirm('Tem certeza que deseja remover este projeto?')\">Remover</a>\r\n                            </span>\r\n                        </td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>ProjetoTesteAdmin3</td>\r\n                        <td>DescricaoProjetoTesteAdmin3</td>\r\n                        \r\n                        <!-- MEDALHAS -->\r\n                        <td>\r\n                            <div>\r\n                                \r\n                                \r\n                                <div class=\"sem-medalhas\">\r\n                                    Nenhuma sessão finalizada\r\n                                </div>\r\n      