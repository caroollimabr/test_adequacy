          "content": {
            "size": 27631,
            "mimeType": "text/html;charset=UTF-8",
            "compression": 0,
            "text": "<!DOCTYPE html>\r\n<html lang=\"pt-br\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta http-equiv=\"Cache-Control\" content=\"no-cache, no-store, must-revalidate\">\r\n    <meta http-equiv=\"Pragma\" content=\"no-cache\">\r\n    <meta http-equiv=\"Expires\" content=\"0\">\r\n    <title>Todos os Projetos (Administrador)</title>\r\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"/favicon.ico\">\r\n    <link rel=\"stylesheet\" href=\"/css/main.css\"/>\r\n    \r\n    <!-- Estilos para as medalhas -->\r\n    <style>\r\n        .medalhas-container {\r\n            display: flex;\r\n            flex-wrap: wrap;\r\n            gap: 8px;\r\n            align-items: center;\r\n        }\r\n        \r\n        .medalha-item {\r\n            display: inline-flex;\r\n            align-items: center;\r\n            background: rgba(0,0,0,0.05);\r\n            padding: 4px 8px;\r\n            border-radius: 12px;\r\n            font-size: 14px;\r\n            font-weight: 500;\r\n            min-width: fit-content;\r\n        }\r\n        \r\n        .medalha-item.ouro {\r\n            background: rgba(255, 215, 0, 0.15);\r\n            color: #B8860B;\r\n            border: 1px solid rgba(24, 21, 4, 0.3);\r\n        }\r\n        \r\n        .medalha-item.prata {\r\n            background: rgba(192, 192, 192, 0.15);\r\n            color: #696969;\r\n            border: 1px solid rgba(192, 192, 192, 0.3);\r\n        }\r\n        \r\n        .medalha-item.bronze {\r\n            background: rgba(205, 133, 63, 0.15);\r\n            color: #c46d2f;\r\n            border: 1px solid rgba(228, 170, 112, 0.3);\r\n        }\r\n        \r\n        .sem-medalhas {\r\n            color: #999;\r\n            font-style: italic;\r\n            font-size: 13px;\r\n        }\r\n        \r\n        /* Responsividade */\r\n        @media (max-width: 768px) {\r\n            .medalhas-container {\r\n                flex-direction: column;\r\n                align-items: flex-start;\r\n                gap: 4px;\r\n            }\r\n            \r\n            .medalha-item {\r\n                font-size: 12px;\r\n                padding: 3px 6px;\r\n            }\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n\r\n<div><header id=\"site-header\">\r\n    <div class=\"header-left\"></div>\r\n\r\n    <div class=\"header-center\">\r\n        <h1>☕ Spring Espresso Game Testing</h1>\r\n    </div>\r\n\r\n    <div class=\"header-right\">\r\n        <form action=\"/logout\" method=\"post\" class=\"logout\">\r\n            <button type=\"submit\" class=\"button button-secondary\">Sair</button>\r\n        </form>\r\n    </div>\r\n</header></div>\r\n\r\n<div class=\"wrapper\">\r\n    \r\n    <h1>Todos os Projetos (Administrador)</h1>\r\n    \r\n    \r\n    \r\n    \r\n    \r\n    \r\n    <p style=\"color: #666; margin-bottom: 20px;\">\r\n        <i>Como administrador, você pode visualizar e gerenciar todos os projetos do sistema.</i>\r\n    </p>\r\n    \r\n\r\n    \r\n    <div style=\"margin-bottom: 20px;\">\r\n        <a href=\"/projetos/novo\" class=\"button button-primary\">Novo Projeto</a>\r\n    </div>\r\n\r\n    <div>\r\n        <div class=\"table-container\">\r\n            <table class=\"data-table\">\r\n                <thead>\r\n                    <tr>\r\n                        <th>Nome</th>\r\n                        <th>Descrição</th>\r\n                        <th>Medalhas por Estratégias</th>\r\n                        <th>Membros</th>\r\n                        <th>Ações</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                    <tr>\r\n                        <td>Projeto Alpha</td>\r\n                        <td>Teste Projeto Alpha</td>\r\n                        \r\n                        <!-- MEDALHAS -->\r\n                        <td>\r\n                            <div>\r\n                                <div class=\"medalhas-container\">\r\n                                     \r\n                                    <span class=\"medalha-item ouro\" \r\n                                          title=\"1 estratégia(s) com 10+ sessões finalizadas\">\r\n                                        <span>1</span>x🥇\r\n                                    </span>\r\n                                    \r\n                                    <span class=\"medalha-item prata\"\r\n                                          title=\"5 estratégia(s) com 5-9 sessões finalizadas\">\r\n                                        <span>5</span>x🥈\r\n                                    </span>\r\n                                    \r\n                                    <span class=\"medalha-item bronze\"\r\n                                          title=\"3 estratégia(s) com 1-4 sessões finalizadas\">\r\n                                        <span>3</span>x🥉\r\n                                    </span>\r\n                                </div>\r\n                                \r\n                                \r\n                            </div>\r\n                        </td>\r\n                        \r\n                        <!-- MEMBROS -->\r\n                        <td class=\"membros-cell\">\r\n                            <span>\r\n                                <div>\r\n                                    <span>Maria Silva</span>\r\n                                </div>\r\n                                <div>\r\n                                    <span>User Usuario</span>\r\n                                </div>\r\n                            </span>\r\n                            \r\n                        </td>\r\n                        \r\n                        <td class=\"actions\">\r\n                            <a href=\"/projetos/detalhes/1\" class=\"button button-secondary\">Ver Detalhes</a>\r\n                            <span>\r\n                                <a href=\"/projetos/editar/1\" \r\n                                   class=\"button button-secondary\">Editar</a>\r\n                                <a href=\"/projetos/remover/1\" \r\n                                   class=\"button button-secondary\" style=\"margin-top: 8px\"\r\n                                   onclick=\"return confirm('Tem certeza que deseja remover este projeto?')\">Remover</a>\r\n                            </span>\r\n                        </td>\r\n                    </tr>\r\n                    <tr>\r\n                        <td>Projeto Beta</td>\r\n                        <td>Teste Projeto Beta</td>\r\n                        \r\n                        <!-- MEDALHAS -->\r\n                        <td>\r\n                            <div>\r\n                                <div class=\"medalhas-container\">\r\n                                     \r\n                                    <span class=\"medalha-item ouro\" \r\n                                          title=\"2 estratégia(s) com 10+ sessões finalizadas\">\r\n                                        <span>2</span>x🥇\r\n                                    </span>\r\n                                    \r\n                                    <span class=\"medalha-item prata\"\r\n                                          title=\"4 estratégia(s) com 5-9 sessões finalizadas\">\r\n                                        <span>4</span>x🥈\r\n                                    </span>\r\n                                    \r\n                                    <span class=\"medalha-item bronze\"\r\n                                          title=\"4 estratégia(s) com 1-4 sessões finalizadas\">\r\n                                        <span>4</span>x🥉\r\n                                    </span>\r\n                                </div>\r\n                                \r\n                                \r\n                            </div>\r\n                        </td>\r\n                        \r\n          