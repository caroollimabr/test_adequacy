          "content": {
            "size": 23265,
            "mimeType": "text/html;charset=UTF-8",
            "compression": 0,
            "text": "<!DOCTYPE html>\r\n<html lang=\"pt-br\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>Cadastro de Projeto</title>\r\n    <link rel=\"stylesheet\" href=\"/css/main.css\"/>\r\n    <link rel=\"stylesheet\" href=\"/css/estrategia-grid.css\"/>\r\n    <style>\r\n        input[type=\"checkbox\"]:disabled + label {\r\n            color: #999;\r\n            cursor: not-allowed;\r\n        }\r\n\r\n        input[type=\"checkbox\"]:disabled {\r\n            cursor: not-allowed;\r\n            opacity: 0.6;\r\n        }\r\n\r\n        .selection-table {\r\n            width: 100%;\r\n            border-collapse: collapse;\r\n            margin-top: 10px;\r\n        }\r\n\r\n        .selection-table th,\r\n        .selection-table td {\r\n            padding: 12px;\r\n            text-align: left;\r\n            border-bottom: 1px solid #ddd;\r\n        }\r\n\r\n        .selection-table th {\r\n            background-color: #f8f9fa;\r\n            font-weight: bold;\r\n        }\r\n\r\n        .selection-table tr:hover {\r\n            background-color: #f5f5f5;\r\n        }\r\n\r\n        /* Adicionar cursor pointer para todas as linhas clicáveis */\r\n        .selection-table tbody tr {\r\n            cursor: pointer;\r\n        }\r\n\r\n        .selection-table tbody tr.disabled-row {\r\n            cursor: not-allowed;\r\n            opacity: 0.7;\r\n        }\r\n\r\n        /* Definir larguras específicas das colunas */\r\n        .selection-table td:first-child,\r\n        .selection-table th:first-child {\r\n            width: 60px;\r\n            text-align: center;\r\n        }\r\n\r\n        .selection-table td:nth-child(2),\r\n        .selection-table th:nth-child(2) {\r\n            width: 25%;\r\n        }\r\n\r\n        .selection-table td:nth-child(3),\r\n        .selection-table th:nth-child(3) {\r\n            width: auto; /* Ocupa o resto do espaço disponível */\r\n        }\r\n\r\n        .selection-table input[type=\"checkbox\"] {\r\n            transform: scale(1.2);\r\n        }\r\n\r\n        .form-section {\r\n            margin-bottom: 40px;\r\n            padding: 20px;\r\n            background-color: #f9f9f9;\r\n            border-radius: 8px;\r\n            border: 1px solid #e0e0e0;\r\n        }\r\n\r\n        .form-section h3 {\r\n            margin-top: 0;\r\n            margin-bottom: 15px;\r\n            color: #333;\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n\r\n<div><header id=\"site-header\">\r\n    <div class=\"header-left\"></div>\r\n\r\n    <div class=\"header-center\">\r\n        <h1>☕ Spring Espresso Game Testing</h1>\r\n    </div>\r\n\r\n    <div class=\"header-right\">\r\n        <form action=\"/logout\" method=\"post\" class=\"logout\">\r\n            <button type=\"submit\" class=\"button button-secondary\">Sair</button>\r\n        </form>\r\n    </div>\r\n</header></div>\r\n\r\n<div class=\"wrapper\">\r\n    <h1>Cadastro de Projeto</h1>\r\n\r\n    \r\n\r\n    <!-- Formulário de Cadastro -->\r\n    <div>\r\n        <form action=\"/projetos/salvar\" method=\"post\">\r\n\r\n            <div class=\"form-group\" style=\"margin-bottom: 20px;\">\r\n                <label for=\"nome\">Nome:</label>\r\n                <input type=\"text\" id=\"nome\" placeholder=\"Nome do projeto\" required name=\"nome\" value=\"\"/>\r\n            </div>\r\n\r\n            <div class=\"form-group\" style=\"margin-bottom: 30px;\">\r\n                <label for=\"descricao\">Descrição:</label>\r\n                <textarea id=\"descricao\" \r\n                          rows=\"4\" \r\n                          placeholder=\"Descrição do projeto\"\r\n                          style=\"width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px;\" name=\"descricao\"></textarea>\r\n            </div>\r\n\r\n            <div class=\"form-section\">\r\n                <h3>Estratégias:</h3>\r\n                <table class=\"selection-table\">\r\n                    <thead>\r\n                        <tr>\r\n                            <th>✓</th>\r\n                            <th>Nome da Estratégia</th>\r\n                            <th>Descrição</th>\r\n                        </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"1\" \r\n                                       id=\"estrategia-cad-1\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-1\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">Newbie</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">Consiste em deixar o jogador ter um primeiro contato com o jogo, e jogar da maneira que achar melhor, sem nenhuma estratégia em mente, apenas para se acostumar com o jogo</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"2\" \r\n                                       id=\"estrategia-cad-2\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-2\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">Golden Path</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">Consiste em apresentar ao jogador a maneira ótima de se jogar, ou seja, seguir o caminho recomendado pelos desenvolvedores, de maneira otimizada e direta, evitando desvios desnecessários, e rotas não desejadas.</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"3\" \r\n                                       id=\"estrategia-cad-3\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-3\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">Noob Journey</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">Tentar jogar o jogo de maneira errada, não seguindo recomendações, e tentando achar maneiras alternativas de realizar as ações (basicamente tentar fazer o contrário do que é recomendado no &quot;Golden Path Strategy&quot;), a fim de descobrir maneiras alternativas de prosseguir no jogo.</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"4\" \r\n                                       id=\"estrategia-cad-4\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-4\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">Completionist</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">Consiste em jogar o jogo de maneira a realizar todas as ações possíveis dentro dele (pegar todas as moedas, matar todos os inimigos, abrir todas as portas, etc), de maneira que não reste mais nenhum objetivo a ser completo.</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"5\" \r\n                                       id=\"estrategia-cad-5\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-5\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">Stress Test</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">Consiste em realizar comandos e inválidos, ou não esperados pelos desenvolvedores, como por exemplo apertar botões que não realizam ações, ou apertá-los de maneira muito rápida, com o intuito de &quot;quebrar&quot; o jogo</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"6\" \r\n                                       id=\"estrategia-cad-6\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-6\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">Speedrun</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">Consiste em tentar finalizar a sessão da maneira mais rápida possível, fazendo o mínimo de ações necessárias para concluir o objetivo.</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"7\" \r\n                                       id=\"estrategia-cad-7\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-7\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">User Interface</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">Testar menus, interfaces e gráficos do jogo, de maneira a ver se estão funcionando da maneira adequada.</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"8\" \r\n                                       id=\"estrategia-cad-8\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-8\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">Neighboring</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">Uma vez encontrado um bug, o usuário tenta encontrar mais deles realizando ações parecidas e em locais próximos, uma vez que a possibilidade de encontrar mais bugs mostra-se maior em áreas onde já foram encontrados outros anteriormente</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"9\" \r\n                                       id=\"estrategia-cad-9\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-9\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">Overtime</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">Testar novamente algum bug conhecido, em um outro momento (aplicar o neighboring após melhorias/evoluções)</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"10\" \r\n                                       id=\"estrategia-cad-10\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-10\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">Automated Testing</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">Execução de testes automatizados para validação de funcionalidades críticas</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"11\" \r\n                                       id=\"estrategia-cad-11\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-11\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">EstrategiaTeste1</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">DescricaoTeste</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"13\" \r\n                                       id=\"estrategia-cad-13\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-13\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">EstrategiaTeste4</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">DescricaoTeste4</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"14\" \r\n                                       id=\"estrategia-cad-14\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-14\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">EstrategiaTeste1</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">DescricaoTeste</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"16\" \r\n                                       id=\"estrategia-cad-16\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-16\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">EstrategiaTeste4</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">DescricaoTeste4</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"17\" \r\n                                       id=\"estrategia-cad-17\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-17\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">EstrategiaTeste1</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">DescricaoTeste</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       value=\"19\" \r\n                                       id=\"estrategia-cad-19\"\r\n                                       checked=\"checked\"\r\n                                       onclick=\"event.stopPropagation()\" name=\"estrategiasIds\"/><input type=\"hidden\" name=\"_estrategiasIds\" value=\"on\"/>\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"estrategia-cad-19\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">EstrategiaTeste4</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">DescricaoTeste4</td>\r\n                        </tr>\r\n                    </tbody>\r\n                </table>\r\n            </div>\r\n\r\n            <div class=\"form-section\">\r\n                <h3>Membros do Projeto:</h3>\r\n                <table class=\"selection-table\">\r\n                    <thead>\r\n                        <tr>\r\n                            <th>✓</th>\r\n                            <th>Nome</th>\r\n                            <th>Email</th>\r\n                        </tr>\r\n                    </thead>\r\n                    <tbody>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       name=\"membrosIds\" \r\n                                       id=\"membro_cad_1\"\r\n                                       value=\"1\"\r\n                                       onclick=\"event.stopPropagation()\">\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"membro_cad_1\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">Admin</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">admin@admin.com</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       name=\"membrosIds\" \r\n                                       id=\"membro_cad_2\"\r\n                                       value=\"2\"\r\n                                       onclick=\"event.stopPropagation()\">\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"membro_cad_2\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">Maria Silva</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">user@user.com</td>\r\n                        </tr>\r\n                        <tr onclick=\"toggleCheckbox(this)\">\r\n                            <td>\r\n                                <input type=\"checkbox\" \r\n                                       name=\"membrosIds\" \r\n                                       id=\"membro_cad_3\"\r\n                                       value=\"3\"\r\n                                       onclick=\"event.stopPropagation()\">\r\n                            </td>\r\n                            <td>\r\n                                <label for=\"membro_cad_3\" \r\n                                       style=\"cursor: pointer; font-weight: bold;\">User Usuario</label>\r\n                            </td>\r\n                            <td style=\"color: #666;\">useruser@user.com</td>\r\n                        </tr>\r\n                    </tbody>\r\n                </table>\r\n            </div>\r\n\r\n            <div style=\"margin-top: 30px;\">\r\n                <button type=\"submit\" class=\"button button-primary\">Salvar</button>\r\n                <a href=\"/projetos/listar\" class=\"button button-secondary\">Cancelar</a>\r\n            </div>\r\n        </form>\r\n    </div>\r\n\r\n    <!-- Formulário de Edição -->\r\n    \r\n</div>\r\n\r\n<footer>\r\n    <p>Spring Espresso Game Testing. Um Software Open-source para a disciplina de Desenvolvimento Web.</p>\r\n    <p>Desenvolvido com café e paixão!</p>\r\n\r\n\r\n\r\n</footer>\r\n\r\n<script>\r\nfunction toggleCheckbox(row) {\r\n    // Procura o checkbox dentro da linha clicada\r\n    const checkbox = row.querySelector('input[type=\"checkbox\"]');\r\n    \r\n    // Verifica se o checkbox não está desabilitado\r\n    if (checkbox && !checkbox.disabled) {\r\n        // Alterna o estado do checkbox\r\n        checkbox.checked = !checkbox.checked;\r\n        \r\n        // Dispara o evento change para caso haja outros listeners\r\n        const event = new Event('change', { bubbles: true });\r\n        checkbox.dispatchEvent(event);\r\n    }\r\n}\r\n</script>\r\n\r\n</body>\r\n</html>"
