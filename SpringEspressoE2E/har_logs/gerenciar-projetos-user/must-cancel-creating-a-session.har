            { "name": "Content-Type", "value": "text/css;charset=UTF-8" },
            { "name": "Date", "value": "Tue, 09 Jun 2026 18:56:56 GMT" },
            { "name": "Keep-Alive", "value": "timeout=60" },
            { "name": "Last-Modified", "value": "Mon, 16 Mar 2026 14:26:08 GMT" },
            { "name": "Vary", "value": "Origin" },
            { "name": "Vary", "value": "Access-Control-Request-Method" },
