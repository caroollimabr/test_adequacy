          "content": {
            "size": 4876,
            "mimeType": "text/html;charset=UTF-8",
            "compression": 0,
            "text": "<!DOCTYPE html>\r\n<html lang=\"pt-br\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>Detalhes do Projeto: Projeto Beta</title>\r\n    <link rel=\"stylesheet\" href=\"/css/main.css\"/>\r\n    <link rel=\"stylesheet\" href=\"/css/estrategia-grid.css\"/>\r\n</head>\r\n<body>\r\n\r\n<div><header id=\"site-header\">\r\n    <div class=\"header-left\"></div>\r\n\r\n    <div class=\"header-center\">\r\n        <h1>☕ Spring Espresso Game Testing</h1>\r\n    </div>\r\n\r\n    <div class=\"header-right\">\r\n        <form action=\"/logout\" method=\"post\" class=\"logout\">\r\n            <button type=\"submit\" class=\"button button-secondary\">Sair</button>\r\n        </form>\r\n    </div>\r\n</header></div>\r\n\r\n<div class=\"wrapper\">\r\n    <h1>Projeto Beta</h1>\r\n    <p style=\"text-align: center;\">Teste Projeto Beta</p>\r\n\r\n    <h2>Estratégias do Projeto</h2>\r\n    <div class=\"strategy-grid\">\r\n        <div class=\"strategy-button bronze-border\">\r\n            <a href=\"/projetos/2/estrategias/5/sessoes\"\r\n               class=\"strategy-button-link\" \r\n               title=\"Sessões finalizadas: 1\">Stress Test</a>\r\n            <div class=\"strategy-session-counter\">\r\n                <span>1 sessão finalizada</span>\r\n            </div>\r\n        </div>\r\n        <div class=\"strategy-button gold-border\">\r\n            <a href=\"/projetos/2/estrategias/10/sessoes\"\r\n               class=\"strategy-button-link\" \r\n               title=\"Sessões finalizadas: 12\">Automated Testing</a>\r\n            <div class=\"strategy-session-counter\">\r\n                <span>12 sessões finalizadas</span>\r\n            </div>\r\n        </div>\r\n        <div class=\"strategy-button silver-border\">\r\n            <a href=\"/projetos/2/estrategias/6/sessoes\"\r\n               class=\"strategy-button-link\" \r\n               title=\"Sessões finalizadas: 6\">Speedrun</a>\r\n            <div class=\"strategy-session-counter\">\r\n                <span>6 sessões finalizadas</span>\r\n            </div>\r\n        </div>\r\n        <div class=\"strategy-button bronze-border\">\r\n            <a href=\"/projetos/2/estrategias/7/sessoes\"\r\n               class=\"strategy-button-link\" \r\n               title=\"Sessões finalizadas: 3\">User Interface</a>\r\n            <div class=\"strategy-session-counter\">\r\n                <span>3 sessões finalizadas</span>\r\n            </div>\r\n        </div>\r\n        <div class=\"strategy-button bronze-border\">\r\n            <a href=\"/projetos/2/estrategias/1/sessoes\"\r\n               class=\"strategy-button-link\" \r\n               title=\"Sessões finalizadas: 4\">Newbie</a>\r\n            <div class=\"strategy-session-counter\">\r\n                <span>4 sessões finalizadas</span>\r\n            </div>\r\n        </div>\r\n        <div class=\"strategy-button silver-border\">\r\n            <a href=\"/projetos/2/estrategias/9/sessoes\"\r\n               class=\"strategy-button-link\" \r\n               title=\"Sessões finalizadas: 5\">Overtime</a>\r\n            <div class=\"strategy-session-counter\">\r\n                <span>5 sessões finalizadas</span>\r\n            </div>\r\n        </div>\r\n        <div class=\"strategy-button silver-border\">\r\n            <a href=\"/projetos/2/estrategias/2/sessoes\"\r\n               class=\"strategy-button-link\" \r\n               title=\"Sessões finalizadas: 7\">Golden Path</a>\r\n            <div class=\"strategy-session-counter\">\r\n                <span>7 sessões finalizadas</span>\r\n            </div>\r\n        </div>\r\n        <div class=\"strategy-button silver-border\">\r\n            <a href=\"/projetos/2/estrategias/8/sessoes\"\r\n               class=\"strategy-button-link\" \r\n               title=\"Sessões finalizadas: 8\">Neighboring</a>\r\n            <div class=\"strategy-session-counter\">\r\n                <span>8 sessões finalizadas</span>\r\n            </div>\r\n        </div>\r\n        <div class=\"strategy-button bronze-border\">\r\n            <a href=\"/projetos/2/estrategias/3/sessoes\"\r\n               class=\"strategy-button-link\" \r\n               title=\"Sessões finalizadas: 2\">Noob Journey</a>\r\n            <div class=\"strategy-session-counter\">\r\n                <span>2 sessões finalizadas</span>\r\n            </div>\r\n        </div>\r\n        <div class=\"strategy-button gold-border\">\r\n            <a href=\"/projetos/2/estrategias/4/sessoes\"\r\n               class=\"strategy-button-link\" \r\n               title=\"Sessões finalizadas: 10\">Completionist</a>\r\n            <div class=\"strategy-session-counter\">\r\n                <span>10 sessões finalizadas</span>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    <a href=\"/\" class=\"button button-secondary\" style=\"margin-top: 15px;\">Main Menu</a>\r\n    <a href=\"/projetos/listar\" class=\"button button-secondary\" style=\"margin-top: 15px;\">Voltar para a Lista</a>\r\n    \r\n</div>\r\n\r\n<footer>\r\n    <p>Spring Espresso Game Testing. Um Software Open-source para a disciplina de Desenvolvimento Web.</p>\r\n    <p>Desenvolvido com café e paixão!</p>\r\n\r\n\r\n\r\n</footer>\r\n\r\n</body>\r\n</html>\r\n"
