          "content": {
            "size": 3525,
            "mimeType": "text/html;charset=UTF-8",
            "compression": 0,
            "text": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>Nova Sessão</title>\r\n    <link rel=\"stylesheet\" href=\"/css/main.css\"/>\r\n    <link rel=\"stylesheet\" href=\"/css/form.css\"/>\r\n</head>\r\n<body>\r\n<div><header id=\"site-header\">\r\n    <div class=\"header-left\"></div>\r\n\r\n    <div class=\"header-center\">\r\n        <h1>☕ Spring Espresso Game Testing</h1>\r\n    </div>\r\n\r\n    <div class=\"header-right\">\r\n        <form action=\"/logout\" method=\"post\" class=\"logout\">\r\n            <button type=\"submit\" class=\"button button-secondary\">Sair</button>\r\n        </form>\r\n    </div>\r\n</header></div>\r\n\r\n<div class=\"wrapper\">\r\n    <h1>Nova Sessão para <span>Projeto Alpha</span> - <span>Noob Journey</span></h1>\r\n\r\n    <form action=\"/sessoes/salvar\" method=\"post\">\r\n        \r\n        <input type=\"hidden\" name=\"projetoId\" value=\"1\" />\r\n        <input type=\"hidden\" name=\"estrategiaId\" value=\"3\" />\r\n\r\n        <div class=\"form-group\" style=\"margin-bottom: 20px;\">\r\n            <label for=\"descricao\">Descrição:</label>\r\n            <textarea id=\"descricao\" \r\n                      name=\"descricao\" \r\n                      rows=\"6\" \r\n                      placeholder=\"Descreva o objetivo e escopo desta sessão de teste...\"\r\n                      style=\"width: 100%; min-height: 120px; resize: vertical; padding: 10px; border: 1px solid #ddd; border-radius: 4px; font-family: inherit;\"\r\n                      required></textarea>\r\n        </div>\r\n\r\n        <div class=\"form-group\" style=\"margin-bottom: 20px;\">\r\n            <label for=\"duracaoMinutos\">Duração (em minutos):</label>\r\n            <input type=\"number\" \r\n                   id=\"duracaoMinutos\" \r\n                   name=\"duracaoMinutos\" \r\n                   min=\"1\" \r\n                   max=\"10000\" \r\n                   placeholder=\"Ex: 60\"\r\n                   style=\"width: 200px; padding: 8px; border: 1px solid #ddd; border-radius: 4px;\"\r\n                   required />\r\n            <small style=\"color: #666; display: block; margin-top: 5px;\">\r\n                Tempo estimado para a sessão\r\n            </small>\r\n        </div>\r\n\r\n        <div class=\"form-group\" style=\"margin-bottom: 30px;\">\r\n            <label for=\"testerId\">Tester Responsável:</label>\r\n            \r\n            \r\n            \r\n            <div>\r\n                <input type=\"text\" \r\n                       value=\"Maria Silva (Você)\" \r\n                       readonly \r\n                       style=\"background-color: #f9f9f9; border: 1px solid #ddd; padding: 8px; border-radius: 4px; width: 100%;\">\r\n                \r\n                <input type=\"hidden\" \r\n                       id=\"testerId\"\r\n                       name=\"testerId\"\r\n                       value=\"2\" />\r\n\r\n                <small style=\"color: #666; display: block; margin-top: 5px;\">\r\n                    Você será automaticamente definido como tester responsável por esta sessão\r\n                </small>\r\n            </div>\r\n            \r\n            \r\n        </div>\r\n\r\n        <div style=\"margin-top: 30px; padding-top: 20px; border-top: 1px solid #eee;\">\r\n            <button type=\"submit\" class=\"button button-primary\">Criar Sessão</button>\r\n            <a href=\"/projetos/1/estrategias/3/sessoes\" \r\n               class=\"button button-secondary\">Cancelar</a>\r\n        </div>\r\n    </form>\r\n</div>\r\n\r\n<footer>\r\n    <p>Spring Espresso Game Testing. Um Software Open-source para a disciplina de Desenvolvimento Web.</p>\r\n    <p>Desenvolvido com café e paixão!</p>\r\n\r\n\r\n\r\n</footer>\r\n</body>\r\n</html>\r\n"
