          "content": {
            "size": 3882,
            "mimeType": "text/html;charset=UTF-8",
            "compression": 0,
            "text": "<!DOCTYPE html>\r\n<html lang=\"pt-br\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <title>Gerenciador de Estratégias</title>\r\n  <link rel=\"stylesheet\" href=\"/css/main.css\"/>\r\n  <link rel=\"stylesheet\" href=\"/css/estrategia-grid.css\"/>\r\n</head>\r\n<body>\r\n<div><header id=\"site-header\">\r\n    <div class=\"header-left\"></div>\r\n\r\n    <div class=\"header-center\">\r\n        <h1>☕ Spring Espresso Game Testing</h1>\r\n    </div>\r\n\r\n    <div class=\"header-right\">\r\n        <form action=\"/logout\" method=\"post\" class=\"logout\">\r\n            <button type=\"submit\" class=\"button button-secondary\">Sair</button>\r\n        </form>\r\n    </div>\r\n</header></div>\r\n\r\n<div class=\"wrapper\">\r\n  <h1>Lista de Estratégias</h1>\r\n\r\n  \r\n  \r\n\r\n  <div style=\"margin-bottom: 20px;\">\r\n    <a href=\"/estrategias/novo\" class=\"button button-primary\">Adicionar Nova Estratégia</a>\r\n  </div>\r\n\r\n  <div>\r\n    <div class=\"strategy-grid\">\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/1\" \r\n           class=\"strategy-button-link\">Newbie</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/2\" \r\n           class=\"strategy-button-link\">Golden Path</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/3\" \r\n           class=\"strategy-button-link\">Noob Journey</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/4\" \r\n           class=\"strategy-button-link\">Completionist</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/5\" \r\n           class=\"strategy-button-link\">Stress Test</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/6\" \r\n           class=\"strategy-button-link\">Speedrun</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/7\" \r\n           class=\"strategy-button-link\">User Interface</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/8\" \r\n           class=\"strategy-button-link\">Neighboring</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/9\" \r\n           class=\"strategy-button-link\">Overtime</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/10\" \r\n           class=\"strategy-button-link\">Automated Testing</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/11\" \r\n           class=\"strategy-button-link\">EstrategiaTeste1</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/13\" \r\n           class=\"strategy-button-link\">EstrategiaTeste4</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/14\" \r\n           class=\"strategy-button-link\">EstrategiaTeste1</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/16\" \r\n           class=\"strategy-button-link\">EstrategiaTeste4</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/17\" \r\n           class=\"strategy-button-link\">EstrategiaTeste1</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/19\" \r\n           class=\"strategy-button-link\">EstrategiaTeste4</a>\r\n      </div>\r\n      <div class=\"strategy-button\">\r\n        <a href=\"/estrategias/detalhes/20\" \r\n           class=\"strategy-button-link\">EstrategiaTeste1</a>\r\n      </div>\r\n    </div>\r\n  </div>\r\n\r\n  \r\n\r\n  <div class=\"navigation-section\">\r\n    <a href=\"/\" class=\"button button-secondary\">Main Menu</a>\r\n</div>\r\n</div>\r\n\r\n<!-- Footer -->\r\n<footer>\r\n    <p>Spring Espresso Game Testing. Um Software Open-source para a disciplina de Desenvolvimento Web.</p>\r\n    <p>Desenvolvido com café e paixão!</p>\r\n\r\n\r\n\r\n</footer>\r\n</body>\r\n</html>\r\n"
