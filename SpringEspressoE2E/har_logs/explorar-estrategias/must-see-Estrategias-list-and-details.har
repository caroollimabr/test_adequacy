          "content": {
            "size": 1047,
            "mimeType": "text/html;charset=UTF-8",
            "compression": 0,
            "text": "<!DOCTYPE html>\r\n<html lang=\"pt-br\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>Login</title>\r\n    <link rel=\"stylesheet\" href=\"/css/main.css\"/>\r\n</head>\r\n<body>\r\n\r\n<div class=\"wrapper\">\r\n    <h2>Login</h2>\r\n\r\n    \r\n    \r\n\r\n    <form action=\"/login\" method=\"post\">\r\n        <div>\r\n            <label for=\"username\">Email:</label>\r\n            <input type=\"text\" id=\"username\" name=\"username\" required autofocus/>\r\n        </div>\r\n        <div>\r\n            <label for=\"password\">Senha:</label>\r\n            <input type=\"password\" id=\"password\" name=\"password\" required/>\r\n        </div>\r\n        <div>\r\n            <button type=\"submit\" class=\"button button-primary\" style=\"margin-top:12px\" id=\"login-button\">Entrar</button>\r\n        </div>\r\n    </form>\r\n    \r\n    <div style=\"margin-top: 20px; text-align: center;\">\r\n        <p>ou</p>\r\n        <a href=\"/estrategias\" class=\"button button-secondary\" id=\"estrategias-convidado-button\">\r\n            Visualizar Estratégias como Convidado\r\n        </a>\r\n    </div>\r\n</div>\r\n\r\n</body>\r\n</html>\r\n"
          },
