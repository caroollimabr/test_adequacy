          "content": {
            "size": 2558,
            "mimeType": "text/html;charset=UTF-8",
            "compression": 0,
            "text": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta http-equiv=\"Cache-Control\" content=\"no-cache, no-store, must-revalidate\">\r\n    <meta http-equiv=\"Pragma\" content=\"no-cache\">\r\n    <meta http-equiv=\"Expires\" content=\"0\">\r\n    <title>Home - Spring Espresso Game Testing</title>\r\n    <link rel=\"icon\" type=\"image/x-icon\" href=\"/favicon.ico\">\r\n    <link rel=\"stylesheet\" href=\"/css/main.css\"/>\r\n</head>\r\n<body>\r\n<div><header id=\"site-header\">\r\n    <div class=\"header-left\"></div>\r\n\r\n    <div class=\"header-center\">\r\n        <h1>☕ Spring Espresso Game Testing</h1>\r\n    </div>\r\n\r\n    <div class=\"header-right\">\r\n        <form action=\"/logout\" method=\"post\" class=\"logout\">\r\n            <button type=\"submit\" class=\"button button-secondary\">Sair</button>\r\n        </form>\r\n    </div>\r\n</header></div>\r\n\r\n<div class=\"wrapper\">\r\n    <h2 style=\"text-align: center;\">\r\n        <span>Bem-vindo(a)</span>,\r\n        <span>user@user.com</span>\r\n        !\r\n    </h2>\r\n    <p style=\"text-align: center; margin-bottom: 30px; color: var(--cafe-medio);\">Sua plataforma para testes de jogos.</p>\r\n\r\n    <div class=\"dashboard-grid\">\r\n\r\n        <!-- Seção Admin - Gerenciar Usuários -->\r\n        \r\n        \r\n        <!-- Botão para Projetos -->\r\n        <div class=\"card\">\r\n            <h3>Gerenciar Projetos</h3>\r\n            <p>Crie, edite e visualize seus projetos de teste.</p>\r\n            <a href=\"/projetos/listar\" class=\"button button-primary\">Ver Projetos</a>\r\n        </div>\r\n\r\n        <!-- Botão para Estratégias -->\r\n        <div class=\"card\">\r\n            <h3>Explorar Estratégias</h3>\r\n            <p>Conheça as diferentes estratégias de playtesting disponíveis.</p>\r\n            <a href=\"/estrategias\" class=\"button button-primary\">Ver Estratégias</a>\r\n        </div>\r\n\r\n        <!-- Botão para Bugs -->\r\n        <div class=\"card\">\r\n            <h3>Bugs Encontrados</h3>\r\n            <p>Analise todos os bugs detectados numa só tela</p>\r\n            <a href=\"bugs/listar\" class=\"button button-primary\">Ver Bugs</a>\r\n        </div>\r\n\r\n\r\n    </div>\r\n<!-- \r\n    <div style=\"text-align: center; margin-top: 40px;\">\r\n        <form th:action=\"@{/logout}\" method=\"post\" class=\"logout\">\r\n            <button type=\"submit\" class=\"button button-secondary\" th:text=\"#{home.botao.sair}\"></button>\r\n        </form>\r\n    </div>\r\n</div>  -->\r\n\r\n<footer>\r\n    <p>Spring Espresso Game Testing. Um Software Open-source para a disciplina de Desenvolvimento Web.</p>\r\n    <p>Desenvolvido com café e paixão!</p>\r\n\r\n\r\n\r\n</footer>\r\n</body>\r\n</html>\r\n"
          },
